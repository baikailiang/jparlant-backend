<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jparlant.mapper.AgentIntentMapper">

    <resultMap id="BaseResultMap" type="com.jparlant.entity.AgentIntent">
        <id column="id" property="id"/>
        <result column="agent_id" property="agentId"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="flow_type" property="flowType"/>
        <result column="metadata_json" property="metadataJson"/>
        <result column="enabled" property="enabled"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM agent_intent ORDER BY created_at DESC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM agent_intent WHERE id = #{id}
    </select>

    <select id="selectByAgentId" resultMap="BaseResultMap">
        SELECT * FROM agent_intent WHERE agent_id = #{agentId} ORDER BY created_at DESC
    </select>

    <insert id="insert" parameterType="com.jparlant.entity.AgentIntent" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO agent_intent (agent_id, name, description, flow_type, metadata_json, enabled, created_at, updated_at)
        VALUES (#{agentId}, #{name}, #{description}, #{flowType}, #{metadataJson}, #{enabled}, NOW(), NOW())
    </insert>

    <update id="updateById" parameterType="com.jparlant.entity.AgentIntent">
        UPDATE agent_intent
        <set>
            <if test="agentId != null">
                agent_id = #{agentId},
            </if>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="description != null">
                description = #{description},
            </if>
            <if test="flowType != null">
                flow_type = #{flowType},
            </if>
            <if test="metadataJson != null">
                metadata_json = #{metadataJson},
            </if>
            <if test="enabled != null">
                enabled = #{enabled},
            </if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM agent_intent WHERE id = #{id}
    </delete>

</mapper>
