<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jparlant.mapper.GlossaryMapper">

    <resultMap id="BaseResultMap" type="com.jparlant.entity.Glossary">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="definition" property="definition"/>
        <result column="category" property="category"/>
        <result column="synonyms" property="synonyms"/>
        <result column="related_names" property="relatedNames"/>
        <result column="examples" property="examples"/>
        <result column="agent_id" property="agentId"/>
        <result column="priority" property="priority"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM glossary ORDER BY priority DESC, created_at DESC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM glossary WHERE id = #{id}
    </select>

    <select id="selectByAgentId" resultMap="BaseResultMap">
        SELECT * FROM glossary WHERE agent_id = #{agentId} ORDER BY priority DESC, created_at DESC
    </select>

    <insert id="insert" parameterType="com.jparlant.entity.Glossary" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO glossary (
            name, definition, category, synonyms, related_names,
            examples, agent_id, priority
        )
        VALUES (
            #{name}, #{definition}, #{category}, #{synonyms}, #{relatedNames},
            #{examples}, #{agentId}, #{priority}
        )
    </insert>

    <update id="updateById" parameterType="com.jparlant.entity.Glossary">
        UPDATE glossary
        SET name = #{name},
            definition = #{definition},
            category = #{category},
            synonyms = #{synonyms},
            related_names = #{relatedNames},
            examples = #{examples},
            agent_id = #{agentId},
            priority = #{priority},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM glossary WHERE id = #{id}
    </delete>

</mapper>
